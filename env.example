PORT=3003

# Redis (required)
REDIS_URL=redis://redis:6379

# Price sources (set at least one)
COINGECKO_PRO_API_KEY=CG-gC89aCXuiKByjzxcUQ3tpu1q
COINMARKETCAP_API_KEY=REPLACE_ME

# Optional: allow using CoinGecko public API when COINGECKO_PRO_API_KEY is not set.
# NOTE: public API is rate-limited; use Pro for production.
COINGECKO_ALLOW_PUBLIC=false

# Optional: extend/override CoinGecko symbol->id mapping without code changes
# Format: SYMBOL=id,SYMBOL2=id2
COINGECKO_SYMBOL_ID_OVERRIDES=

BSC_RPC_URL=https://bsc-dataseed1.binance.org
VEILX_CONTRACT_ADDRESS=0x9C79B4a12eF8176B6a61142408A54Edf8336b0A6
# Optional overrides
PANCAKE_ROUTER_V2_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E
BSC_USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# Cache TTLs (seconds)
PRICE_CACHE_TTL_SECONDS=120
REQUEST_CACHE_TTL_SECONDS=30

# Across Bridge directory proxy (dynamic supported chains/routes + allowlist downlink)
# NOTE: mobile app calls this backend; keep allowlist small initially and expand gradually.
BRIDGE_ACROSS_API_BASE_URL=https://app.across.to/api
BRIDGE_ACROSS_TIMEOUT_MS=12000
BRIDGE_ACROSS_CHAINS_CACHE_TTL_SECONDS=300
BRIDGE_ACROSS_ROUTES_CACHE_TTL_SECONDS=60
# Allowlist mode: STRICT (filter by allowlist) | FULL (no filtering; return all Across-supported chains/tokens/routes)
BRIDGE_ACROSS_ALLOWLIST_MODE=FULL
BRIDGE_ACROSS_ALLOWED_CHAIN_IDS=1,10,42161,8453,56
BRIDGE_ACROSS_ALLOWED_TOKEN_SYMBOLS=ETH,USDC,USDT,DAI,USDC-BNB,USDT-BNB

# CORS (comma separated, default: *)
CORS_ALLOWED_ORIGINS=*

# Android app update
# Enable backend app update checks for the mobile client.
APP_UPDATE_ANDROID_ENABLED=false
APP_UPDATE_ANDROID_CHANNEL=official
APP_UPDATE_ANDROID_PACKAGE_NAME=com.statusmvp
# Preferred: point to a published manifest JSON over HTTPS.
APP_UPDATE_ANDROID_MANIFEST_URL=
APP_UPDATE_ANDROID_MANIFEST_CACHE_TTL_SECONDS=300
# Optional inline fallback when MANIFEST_URL is empty.
APP_UPDATE_ANDROID_LATEST_VERSION_CODE=0
APP_UPDATE_ANDROID_LATEST_VERSION_NAME=
APP_UPDATE_ANDROID_MIN_SUPPORTED_VERSION_CODE=0
APP_UPDATE_ANDROID_REQUIRED=false
APP_UPDATE_ANDROID_DOWNLOAD_URL=
APP_UPDATE_ANDROID_SHA256=
APP_UPDATE_ANDROID_FILE_SIZE_BYTES=0
APP_UPDATE_ANDROID_RELEASE_NOTES=
APP_UPDATE_ANDROID_PUBLISHED_AT=0

# Safe notifications
# The backend can always fall back to pull_local_notification.
# Configure these explicitly in production so push behavior does not depend on repository defaults.
SAFE_NOTIFICATIONS_ENABLED=true
SAFE_NOTIFICATIONS_POLL_DELAY_MS=45000
SAFE_NOTIFICATIONS_INBOX_LIMIT=50
SAFE_NOTIFICATIONS_PULL_DEFAULT_LIMIT=20
SAFE_NOTIFICATIONS_QUEUE_TTL_SECONDS=1209600

# Android remote push (FCM)
APP_SAFE_NOTIFICATIONS_REMOTE_FCM_ENABLED=false
APP_SAFE_NOTIFICATIONS_REMOTE_FCM_PROJECT_ID=
APP_SAFE_NOTIFICATIONS_REMOTE_FCM_CLIENT_EMAIL=
APP_SAFE_NOTIFICATIONS_REMOTE_FCM_PRIVATE_KEY_PEM=

# iOS remote push (APNS)
APP_SAFE_NOTIFICATIONS_REMOTE_APNS_ENABLED=false
APP_SAFE_NOTIFICATIONS_REMOTE_APNS_TEAM_ID=
APP_SAFE_NOTIFICATIONS_REMOTE_APNS_KEY_ID=
APP_SAFE_NOTIFICATIONS_REMOTE_APNS_BUNDLE_ID=com.veilwallet.app
APP_SAFE_NOTIFICATIONS_REMOTE_APNS_PRIVATE_KEY_PEM=
APP_SAFE_NOTIFICATIONS_REMOTE_APNS_USE_SANDBOX=true

# Legal pages used by app links (e.g. /terms, /privacy)
# Leave empty to use backend built-in legal pages.
LEGAL_TERMS_URL=
LEGAL_PRIVACY_URL=
LEGAL_SUPPORT_URL=
LEGAL_APP_NAME=Veil Wallet
LEGAL_ENTITY_NAME=VeilLabs
LEGAL_CONTACT_EMAIL=veillabs.wallet@gmail.com
LEGAL_CONTACT_ADDRESS=香港九龙区
LEGAL_EFFECTIVE_DATE=2026-02-20
LEGAL_GOVERNING_LAW=Laws of the Hong Kong Special Administrative Region
LEGAL_GOVERNING_LAW_ZH=香港特别行政区法律

# ==========================================
# Safe Tx Service proxy (multisig Phase 1)
# ==========================================
SAFE_TX_SERVICE_BASE_URL=https://api.safe.global/tx-service
SAFE_TX_PROXY_ENABLED=false
# Optional (Bearer token). Keep server-side; do NOT put in the mobile app.
SAFE_TX_SERVICE_API_KEY=REPLACE_ME
SAFE_TX_SERVICE_TIMEOUT_MS=12000
SAFE_TX_UPSTREAM_RPS=4
SAFE_TX_UPSTREAM_BURST=4

# Safe Tx Service Gateway (Plan A) rate limits
SAFE_TX_GW_RL_WINDOW_SECONDS=60
SAFE_TX_GW_RL_IP_LIMIT=600
SAFE_TX_GW_RL_DEVICE_LIMIT=300

# ==========================================
# Solana Jupiter proxy (DEX quote/swap)
# ==========================================
# Mobile app may be unable to reach *.jup.ag directly on some networks.
# Proxy through this backend to improve reliability and control timeouts/rate limits.
JUPITER_LITE_API_BASE_URL=https://lite-api.jup.ag/swap/v1
JUPITER_TIMEOUT_MS=12000
JUPITER_RL_WINDOW_SECONDS=60
JUPITER_RL_IP_LIMIT=600

# ==========================================
# Social login auth server (M1)
# ==========================================
AUTH_ENABLED=true
AUTH_X_ENABLED=true
AUTH_TG_ENABLED=true
AUTH_SYNC_ENABLED=true
AUTH_BIND_ENABLED=true
AUTH_METRICS_ENABLED=true

# One-time auth code TTL (seconds).
# - App flow exchanges immediately, but manual testing or slow networks may exceed 60s.
# - Recommended for dev/staging: 180-300. Production can keep 60-120.
AUTH_ONE_TIME_CODE_TTL_SECONDS=180
AUTH_OAUTH_STATE_TTL_SECONDS=600
AUTH_WEB3AUTH_JWT_TTL_SECONDS=300
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_SIWE_NONCE_TTL_SECONDS=600
# SIWE statement shown in the signed message
AUTH_SIWE_STATEMENT=VeilWallet wants you to sign in.

AUTH_WEB3AUTH_ISSUER=https://auth.status-mvp.local
AUTH_WEB3AUTH_AUDIENCE=status-mvp
AUTH_WEB3AUTH_KEY_ID=status-mvp-auth-v1
# Optional: Web3Auth dashboard credentials (keep server-side; do NOT put in the mobile app).
AUTH_WEB3AUTH_CLIENT_ID=
AUTH_WEB3AUTH_CLIENT_SECRET=
# RSA private key in PEM format. Required in production.
AUTH_WEB3AUTH_PRIVATE_KEY_PEM=

AUTH_APP_JWT_ISSUER=status-mvp-price-backend
AUTH_APP_JWT_AUDIENCE=status-mvp-app
# At least 32 bytes random secret in production.
AUTH_APP_JWT_SECRET=
# iOS release builds should require a per-request device proof signature for high-risk auth flows.
AUTH_IOS_DEVICE_PROOF_ENABLED=true
# Android release/direct builds should also require per-request device proof signatures backed by Android Keystore.
AUTH_ANDROID_DEVICE_PROOF_ENABLED=true
AUTH_ANDROID_PLAY_INTEGRITY_ENABLED=true
# High-risk Android social auth/bind endpoints are only allowed on these distribution channels.
# Keep this as `play` in production so sideload/direct builds cannot create or bind cloud identities.
AUTH_ANDROID_PROTECTED_AUTH_ALLOWED_CHANNELS=play
AUTH_DEVICE_PROOF_CHALLENGE_TTL_SECONDS=60
AUTH_ANDROID_PLAY_INTEGRITY_FRESHNESS_SECONDS=180
AUTH_ANDROID_PLAY_INTEGRITY_PACKAGE_NAME=com.statusmvp
# Google Cloud service-account credentials used to call playintegrity.googleapis.com:decodeIntegrityToken.
AUTH_ANDROID_PLAY_INTEGRITY_SERVICE_ACCOUNT_EMAIL=
AUTH_ANDROID_PLAY_INTEGRITY_SERVICE_ACCOUNT_PRIVATE_KEY_PEM=
AUTH_IOS_APP_ATTEST_ENABLED=true
AUTH_APP_ATTEST_CHALLENGE_TTL_SECONDS=60
AUTH_APP_ATTEST_ASSERTION_CHALLENGE_TTL_SECONDS=60
AUTH_IOS_ALLOWED_APPLICATION_IDENTIFIERS=4592CM9497.com.veilwallet.app

# Allowed callback redirect prefixes for app deep links (comma-separated).
# Keep the HTTPS app/universal-link callback first, and keep the dedicated Web3Auth custom scheme as compatibility fallback.
# Example: https://wallet.example.com/openlogin,veilwalletw3a://openlogin
AUTH_APP_REDIRECT_ALLOWLIST=https://vex.veilx.global/openlogin,veilwalletw3a://openlogin
# Canonical external base URL for auth callback pages. Set this in production to avoid host-header spoofing.
AUTH_PUBLIC_BASE_URL=https://vex.veilx.global

# Mobile HTTPS app/universal-link association files served by this backend.
APP_LINKS_IOS_APP_IDS=4592CM9497.com.veilwallet.app
APP_LINKS_PATH_PREFIX=/openlogin
APP_LINKS_ANDROID_PACKAGE_NAME=com.statusmvp
# Comma-separated SHA-256 certificate fingerprints for Android app links verification.
APP_LINKS_ANDROID_SHA256_CERT_FINGERPRINTS=

# X OAuth
AUTH_X_CLIENT_ID=
AUTH_X_CLIENT_SECRET=
AUTH_X_REDIRECT_URI=
# Optional but recommended (multi-node): enables stateless state + deterministic PKCE verifier derivation.
# MUST be the same across all nodes, at least 32 bytes.
AUTH_X_STATE_SECRET=replace-me-with-strong-random-secret-at-least-32-bytes
AUTH_X_SCOPES=tweet.read users.read offline.access
AUTH_X_AUTHORIZE_ENDPOINT=https://twitter.com/i/oauth2/authorize
AUTH_X_TOKEN_ENDPOINT=https://api.twitter.com/2/oauth2/token
AUTH_X_USERINFO_ENDPOINT=https://api.twitter.com/2/users/me

# Telegram login
# Preferred main path: hosted Telegram login page with official Telegram JS and server-side id_token verification.
# If AUTH_TG_CLIENT_ID is blank, the backend will derive it from AUTH_TG_BOT_TOKEN's numeric prefix.
AUTH_TG_CLIENT_ID=
# Optional compatibility path for direct OIDC authorization-code flow.
AUTH_TG_CLIENT_SECRET=
AUTH_TG_REDIRECT_URI=https://vex.veilx.global/api/v1/auth/tg/login
# Optional but recommended (multi-node): enables stateless state tokens for Telegram login.
# MUST be the same across all nodes, at least 32 bytes.
AUTH_TG_STATE_SECRET=replace-me-with-strong-random-secret-at-least-32-bytes
AUTH_TG_SCOPES=openid,profile
AUTH_TG_ISSUER=https://oauth.telegram.org
AUTH_TG_AUTHORIZE_ENDPOINT=https://oauth.telegram.org/auth
AUTH_TG_TOKEN_ENDPOINT=https://oauth.telegram.org/token
AUTH_TG_JWKS_URI=https://oauth.telegram.org/.well-known/jwks.json
# Required for the hosted Telegram login page and legacy widget fallback.
AUTH_TG_BOT_TOKEN=
# Telegram bot username (without "@"). Required for the Telegram Login Widget page.
AUTH_TG_BOT_USERNAME=
AUTH_TG_AUTH_MAX_AGE_SECONDS=600
# Keep legacy Telegram Login Widget disabled unless you intentionally need the old flow.
AUTH_TG_LEGACY_WIDGET_ENABLED=true

# Apple Sign In
AUTH_APPLE_ENABLED=true
# Comma-separated bundle IDs / client IDs accepted as the Apple identity token audience.
AUTH_APPLE_AUDIENCES=com.veilwallet.app
AUTH_APPLE_ISSUER=https://appleid.apple.com
AUTH_APPLE_JWKS_URI=https://appleid.apple.com/auth/keys

# Risk control
AUTH_RISK_BLACKLIST_IPS=
AUTH_RISK_BLACKLIST_PROVIDER_SUBS=
AUTH_RISK_TRUSTED_PROXY_IPS=127.0.0.1,::1
AUTH_RISK_LOGIN_IP_LIMIT=20
AUTH_RISK_LOGIN_DEVICE_LIMIT=30
AUTH_RISK_BIND_ACCOUNT_LIMIT=20
AUTH_RISK_WINDOW_SECONDS=60
